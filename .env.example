# MiniURL Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# ⚠️ SECURITY NOTICE ⚠️
# ===========================================
# BEFORE DEPLOYING TO PRODUCTION:
# 1. Generate a NEW JWT secret (see JWT section below)
# 2. Set ALL required passwords (no defaults provided)
# 3. Use strong, unique passwords for all services
# 4. Enable HTTPS in production
# ===========================================

# ===========================================
# DATABASE CONFIGURATION - REQUIRED
# ===========================================
# For Docker setup: MySQL runs in Docker container
# For local setup: MySQL must be running externally

# Docker MySQL Configuration (used by docker-compose.yml)
# ⚠️ THESE VALUES MUST BE SET - NO DEFAULTS PROVIDED
# Generate secure passwords using: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=miniurldb
MYSQL_USER=
MYSQL_PASSWORD=

# Application Database Connection (for Spring Boot)
# For Docker: use 'mysql' hostname (Docker service name)
# For local MySQL: use your hostname or IP
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/miniurldb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Note: Database is auto-initialized by Docker on first startup
# Manual init (if needed): bash scripts/init-db.sh

# ===========================================
# JWT CONFIGURATION - CRITICAL FOR SECURITY
# ===========================================
# ⚠️ REQUIRED: Generate a NEW secret for production!
# The application will FAIL TO START with the default secret.
#
# Generate a secure key (min 32 characters):
#   openssl rand -base64 64
#
# Or use this online generator:
#   https://generate-secret.vercel.app/64
APP_JWT_SECRET=YOUR_SECURE_SECRET_HERE_GENERATE_NEW_ONE

# JWT token expiration in milliseconds (default: 60 minutes)
APP_JWT_EXPIRATION_MS=3600000

# ===========================================
# SMTP CONFIGURATION (Email Service)
# ===========================================
# SMTP server host (e.g., smtp.gmail.com for Gmail)
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP username (usually your email address)
SMTP_USERNAME=your-email@gmail.com

# SMTP password
# For Gmail: Use App Password if 2FA is enabled
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
# Base URL for the API (used in email links and CORS)
# For production:
#   - If API is on same domain as UI: https://example.com
#   - If API is on subdomain: https://api.example.com
#   - If API is on different domain: https://your-api-domain.com
APP_BASE_URL=https://api.example.com

# OTP expiration time in minutes
APP_OTP_EXPIRY_MINUTES=15

# CORS Allowed Origins (comma-separated)
# For production with frontend on ui.example.com:
#   APP_CORS_ALLOWED_ORIGINS=https://ui.example.com
# For multiple origins (e.g., with www):
#   APP_CORS_ALLOWED_ORIGINS=https://ui.example.com,https://www.example.com
APP_CORS_ALLOWED_ORIGINS=https://ui.example.com

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Server port (host machine)
SERVER_PORT=8080

# ===========================================
# DOCKER CONFIGURATION
# ===========================================
# Application container port (host machine)
APP_PORT=8080

# Debug port for development (Docker Compose dev only)
DEBUG_PORT=5005

# ===========================================
# NOTES
# ===========================================
# 1. Docker Setup (Recommended):
#    - MySQL runs automatically in Docker container
#    - Database is auto-initialized on first startup
#    - All services communicate via Docker network
#    - No external MySQL configuration needed
#
# 2. Quick Start with Docker:
#    - Copy .env.example to .env
#    - Generate NEW JWT secret: openssl rand -base64 64
#    - Update APP_JWT_SECRET in .env
#    - Run: docker compose up -d
#    - Access: http://localhost:8080
#    - Default admin: admin / admin123# (CHANGE IMMEDIATELY!)
#
# 3. For Gmail SMTP:
#    - Enable 2-Factor Authentication
#    - Generate App Password: https://myaccount.google.com/apppasswords
#    - Use the App Password as SMTP_PASSWORD
#
# 4. PRODUCTION SECURITY CHECKLIST:
#    ✅ Generate NEW APP_JWT_SECRET (app fails with default)
#    ✅ Change MYSQL_ROOT_PASSWORD
#    ✅ Change MYSQL_PASSWORD
#    ✅ Change admin password immediately after first login
#    ✅ Set APP_BASE_URL to HTTPS production domain
#    ✅ Set APP_CORS_ALLOWED_ORIGINS to frontend domain(s)
#    ✅ Enable HTTPS/TLS on your server (reverse proxy)
#    ✅ Review and secure all default passwords
#    ✅ Consider using external MySQL for data persistence
#
# 5. Email verification is optional:
#    - If SMTP is not configured, OTPs will be logged to console
#    - Useful for development/testing without email setup
#
# 6. Password Requirements:
#    - Minimum 8 characters
#
# 7. Data Persistence:
#    - MySQL data is stored in Docker volume: mysql-data
#    - To backup: docker run --rm -v miniurl_mysql-data:/data -v $(pwd):/backup alpine tar czf /backup/mysql-backup.tar.gz -C /data .
#    - To restore: reverse the backup process
#
# 8. Logging Configuration (Optional):
#    - LOG_DIR: Directory where log files are stored (default: ./logs)
#    - LOG_FILE: Base name for log files (default: miniurl)
#    - MAX_FILE_SIZE: Max size before rotation (default: 10MB)
#    - MAX_HISTORY: Days to keep logs (default: 30)
#    - TOTAL_SIZE_CAP: Max total log size (default: 1GB)
#
#    Example:
#    LOG_DIR=/var/log/miniurl
#    MAX_FILE_SIZE=50MB
#    MAX_HISTORY=90
#    TOTAL_SIZE_CAP=5GB
