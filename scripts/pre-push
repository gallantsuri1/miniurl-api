#!/bin/bash

# Pre-push hook to prevent direct commits to protected branches
# This hook prevents direct pushes to main/master branches
# and requires pull requests for all changes

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Protected branches
PROTECTED_BRANCHES=("main" "master")

# Get the current branch we're pushing to
while read local_ref local_sha remote_ref remote_sha; do
    # Extract branch name from remote ref
    branch=$(echo "$remote_ref" | sed 's|refs/heads/||')
    
    # Check if pushing to a protected branch
    for protected in "${PROTECTED_BRANCHES[@]}"; do
        if [ "$branch" = "$protected" ]; then
            echo -e "${RED}❌ ERROR: Direct push to '$protected' branch is not allowed!${NC}"
            echo ""
            echo -e "${YELLOW}Please follow these steps:${NC}"
            echo "  1. Create a new branch: ${GREEN}git checkout -b feature/your-feature${NC}"
            echo "  2. Commit your changes: ${GREEN}git commit -m 'Your message'${NC}"
            echo "  3. Push your branch: ${GREEN}git push origin feature/your-feature${NC}"
            echo "  4. Create a Pull Request on GitHub"
            echo ""
            echo -e "${YELLOW}For more information, see the repository's CONTRIBUTING guide.${NC}"
            echo ""
            exit 1
        fi
    done
done

# If we get here, all checks passed
exit 0
